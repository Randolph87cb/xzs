{
  "name": "xzs-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev:student": "pnpm --filter @xzs/student dev",
    "build:student": "pnpm --filter @xzs/student build",
    "preview:student": "pnpm --filter @xzs/student preview",
    "test:question-renderer": "pnpm --filter @xzs/question-renderer test",
    "verify:student-ui": "node scripts/verify-student-ui-screenshots.mjs",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@xzs/config": "workspace:*",
    "playwright": "1.57.0",
    "typescript": "6.0.3"
  }
}
