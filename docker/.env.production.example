XZS_IMAGE=crpi-s5bag0a5r8vcgncq.cn-hangzhou.personal.cr.aliyuncs.com/randolph87/gesp-csp-quiz:latest
XZS_HOST_PORT=8000

# Production must use Neon production branch.
SPRING_DATASOURCE_URL=postgresql://<user>:<password>@<production-branch-host>/<database>?sslmode=require&channel_binding=require
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=4
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

# Keep this value stable. Rotating it requires re-saving encrypted AI API keys.
XZS_AI_CONFIG_SECRET=<production-secret-32-chars-or-longer>

JAVA_TOOL_OPTIONS=-Xms128m -Xmx512m -XX:+UseSerialGC
SERVER_UNDERTOW_IO_THREADS=2
SERVER_UNDERTOW_WORKER_THREADS=16
SERVER_UNDERTOW_BUFFER_SIZE=512
SERVER_UNDERTOW_DIRECT_BUFFERS=false
